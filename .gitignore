# OpenAlpha-Brain — Git Ignore Rules

# ── Environment — NEVER commit secrets ──────────────────
.env
.env.local
.env.*.local

# ── Python ───────────────────────────────────────────────
__pycache__/
*[Bb]in/
[Ll]ib/
*[Ss]cript*/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Virtual environments ─────────────────────────────────
venv/
.venv/
env/
.env.bak

# ── Runtime data (auto-generated, large, non-source) ─────
sessions/
sessions/*/
runtime/
logs/
logs/*/
*.log

# Root-level runtime JSON artifacts (duplicates of src/ data)
alpha_tools.json
evolution_db.json
rag_feedback_weights.json
strategy_profiles.json
ast_fingerprints.json
experience_cards.json
feature_map.json
mab_state.json

# Temp files
*.tmp
alpha_run_log.txt
_last_session_id.txt

# ── IDE ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Frontend ─────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/

# ── Trae / AI memory (local only) ─────────────────────────
.trae/
.trae-cn/

# ── Misc ─────────────────────────────────────────────────
*.bak
*.orig

# ── Reference material (read-only copies, DO NOT commit) ──
素材仓库禁止直接引用，可复制代码/

# ── Temp dev scripts (one-shot refactor/fix helpers) ──────
_*.py
_*.json
f821.json
